# Lokální Playwright E2E konfigurace.
# Soubor zkopíruj do .env.test.local a doplň lokální klíče z `npx supabase status`.

PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
E2E_MAILPIT_URL=http://127.0.0.1:54324

NEXT_PUBLIC_SUPABASE_REDIRECT_URL=http://127.0.0.1:3000/rezervace
NEXT_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=http://127.0.0.1:3000/rezervace
