{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp-tests",
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "isolatedModules": false,
    "incremental": false,
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "tests/**/*.ts",
    "app/admin/stale-recovery.ts",
    "lib/services/supabase-error-mapping.ts",
    "lib/supabase/client.ts",
    "lib/services/reservations.ts",
    "lib/services/profile-save-error.ts",
    "lib/services/reservation-occupancy.ts"
  ]
}
